  "colorsActivelyUsed": ["lavender", "tangerine", "blueberry", "basil", "banana", "sage"],
  "sleepPolicy": {
    "note": "Night sleep is inferred from empty calendar gaps 00:00–08:00; explicit sleep labels count. Off-window sleep and siesta/nap → rest (recovery), not self-care."
  },
  "productPrinciples": [
    "Interpretation is wrong without the user's color and labeling system — ask how they code and annotate.",
    "Cryptic titles (friend names, party names) deserve a one-time clarifying question, not a silent guess.",
    "When a label is taught once (e.g. chermi = DJing), store it in keywordOverrides and reuse."
  ],
  "labelClarifications": {
    "productNote": "v1: config + onboarding. v1.1: prompt on first unknown label in a week.",
    "resolved": []
  },
  "compoundBlocks": {
    "note": "Friend's name on banana (Lua) or basil (meal) = social + pet/meal together.",
    "insightFraming": "Integration you enjoy—not double-booking hustle.",
    "types": ["social_plus_pets", "social_plus_meals", "social_plus_radio_errand", "radio_plus_djing"]
  },
  "relatedBlocks": {
    "description": "One calendar block often belongs to more than one life area. Count or link without treating it as an error.",
    "rules": [
      {
        "id": "caprixxo_dual",
        "keywords": ["caprixxo"],
        "areas": ["radio", "djing_music"],
        "countStrategy": "both",
        "note": "CAPRIXXO spans radio and DJing — track in both"
      },
      {
        "id": "lavender_radio_errand",
        "keywords": ["isa enes", "isaenes"],
        "areas": ["social_life", "radio"],
        "countStrategy": "both",
        "matchHint": "lavender + person-name errand (pickup, handoff)",
        "userExamples": ["Isa Enes — pick something up from my house"],
        "onboardingPrompt": "Some lavender blocks are social but also radio logistics — link both?"
      }
    ]
  }

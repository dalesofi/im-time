        {
          "keywords": [
            "ropa",
            "colada",
            "laundry",
            "wardrobe"
          ],
          "lifeAreaId": "laundry",
          "match": "title_contains"
        },
        {
          "keywords": [
            "siesta",
            "podcast",
            "radio"
          ],
          "lifeAreaId": "day_rest",
          "match": "title_contains"
        }
      ]
    },
    "tangerine": {
      "id": "tangerine",
